---
# Template for secrets consumed by group_vars/all.yml.
#
# Copy this file to `vault.yml` (same directory), fill in real values,
# then encrypt it before committing anything:
#
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# Never commit an unencrypted vault.yml - it is intentionally not
# tracked in this template's real form, only as this .example file.

vault_mysql_root_password: "CHANGE_ME"
vault_aws_key: "CHANGE_ME"
vault_aws_secret: "CHANGE_ME"
